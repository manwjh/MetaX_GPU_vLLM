BASE_IMAGE=cr.metax-tech.com/public-ai-release/maca/vllm-metax:0.15.0-maca.ai3.5.3.203-torch2.8-py310-ubuntu22.04-amd64
IMAGE_NAME=muxi_gemma4_26B_TP1:2026-04-16
CONTAINER_NAME=muxi_gemma4_26B_TP1
HOST_PORT=18010
MODEL_PATH=/data/gemma-4-26B-A4B-it
SERVED_MODEL_NAME=gemma-4-26B-A4B-it
CUDA_VISIBLE_DEVICES=6
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096
GPU_MEM_UTIL=0.88
VLLM_ATTENTION_BACKEND=TRITON_ATTN
TRITON_DISABLE_SWIZZLE=1
REASONING_PARSER=gemma4
GEMMA4_DEFAULT_ENABLE_THINKING=0
GEMMA4_USE_DEFAULT_CHAT_TEMPLATE_KWARGS=1
GEMMA4_USE_BOOTSTRAP=1
VLLM_ENABLE_PREFIX_CACHING=0
VLLM_CHUNKED_PREFILL=0
VLLM_ENFORCE_EAGER=1
MACA_GRAPH_LAUNCH_MODE=1
# 可选：追加传给 vLLM OpenAI api_server 的 CLI（调度等），例如：
# VLLM_APISERVER_EXTRA=--max-num-seqs 128 --max-num-batched-tokens 8192
